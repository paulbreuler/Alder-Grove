{
  "name": "alder-grove",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit",
    "ai:generate": "tsx scripts/generate-ai-configs.ts",
    "ai:check": "tsx scripts/generate-ai-configs.ts --check",
    "prepare": "husky",
    "generate:types": "node scripts/generate-types.mjs",
    "precheck": "node scripts/generate-types.mjs",
    "pretest": "node scripts/generate-types.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@clerk/react": "^6.1.0",
    "@paulbreuler/shell": "0.9.0-dev.9c145a3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  }
}
