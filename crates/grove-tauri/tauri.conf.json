{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/tauri-v2.10.3/crates/tauri-utils/schema.json",
  "productName": "Alder Grove",
  "version": "0.1.0",
  "identifier": "com.aldergrove.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Alder Grove",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "theme": "Dark",
        "center": true
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["grove"]
      }
    }
  }
}
